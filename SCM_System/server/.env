JWT_SECRET=mysecretkey123

# Welcome Email Service (Nodemailer)
# -------------------------------------------------------------
# STEP 1: Uncomment and fill in the following values to send real emails.
# STEP 2: Use your personal Gmail (with "App Password") or a service like Sengrid/Mailtrap.
# If these are missing, the system will fallback to "Ethereal Email" for development.

EMAIL_FROM="Student Complaint System <no-reply@scm.edu>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_WITH_YOUR_EMAIL@gmail.com
SMTP_PASS=REPLACE_WITH_YOUR_APP_PASSWORD